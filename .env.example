# Copy to .env and fill in. .env is gitignored.
# Required for the Auto-Compose agent (✨ التأليف التلقائي).
OPENAI_API_KEY=sk-...

# Flagship by default; override to gpt-5.5-pro (higher) or gpt-5.4-mini (cheaper).
OPENAI_MODEL=gpt-5.5

# Optional fixed temperature. Leave unset for GPT-5.x reasoning models (they reject it).
# OPENAI_TEMPERATURE=0.7

# Memory safety defaults for local TTS workers.
# Keep only one heavyweight Python model loaded at a time through the gateway.
TTS_SINGLE_MODEL=1
# Unload idle Python models after 15 minutes. Set 0 to disable idle unload.
TTS_MODEL_IDLE_SECONDS=900
# Reject oversized synthesis requests before they can fill RAM.
TTS_MAX_REQUEST_BYTES=33554432
TTS_MAX_UPLOAD_BYTES=26214400
TTS_MAX_TEXT_CHARS=8000

# Root of the TTS training/work project (holds outputs_* dirs and the
# omnivoice/checkpoints tree). Default: ~/tts-05172026
# TTS_WORKDIR=/mnt/e/wsl-projects/tts-05172026

# Force a specific OmniVoice model instead of auto-detection.
# Auto order: $TTS_WORKDIR/omnivoice/checkpoints/best_finetuned -> k2-fsa/OmniVoice
# OMNIVOICE_MODEL_ID=k2-fsa/OmniVoice

# Directory of bundled clone voices. Default: <repo>/voices
# TTS_VOICES_DIR=
